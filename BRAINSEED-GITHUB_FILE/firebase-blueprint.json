{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and learning progress",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "grade": { "type": "string" },
        "language": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "points": { "type": "number" },
        "currentStreak": { "type": "number" },
        "lastLoginDate": { "type": "string" },
        "activityLog": { "type": "array"}
      },
      "required": ["name", "grade", "language", "interests", "points"]
    },
    "DiaryNote": {
      "title": "Diary Note",
      "description": "Parent's observations about child's progress",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "parentUid": { "type": "string" },
        "childName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "parentUid", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles keyed by UID"
    },
    "seed_diary/{noteId}": {
      "schema": "DiaryNote",
      "description": "Parent's diary notes for child progress"
    }
  }
}
